{
  "openapi": "3.1.1",
  "info": {
    "title": "WebApiDemo | v1",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://localhost:7266"
    },
    {
      "url": "http://localhost:5246"
    }
  ],
  "paths": {
    "/auth": {
      "post": {
        "tags": [
          "Authority"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AppCredential"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/AppCredential"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/AppCredential"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Shirts": {
      "get": {
        "tags": [
          "Shirts"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
      "post": {
        "tags": [
          "Shirts"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Shirt"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/Shirt"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/Shirt"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Shirts/{id}": {
      "get": {
        "tags": [
          "Shirts"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "pattern": "^-?(?:0|[1-9]\\d*)$",
              "type": [
                "integer",
                "string"
              ],
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
      "put": {
        "tags": [
          "Shirts"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "pattern": "^-?(?:0|[1-9]\\d*)$",
              "type": [
                "integer",
                "string"
              ],
              "format": "int32"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Shirt"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/Shirt"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/Shirt"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
      "delete": {
        "tags": [
          "Shirts"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "pattern": "^-?(?:0|[1-9]\\d*)$",
              "type": [
                "integer",
                "string"
              ],
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AppCredential": {
        "type": "object",
        "properties": {
          "clientId": {
            "type": "string"
          },
          "secret": {
            "type": "string"
          }
        }
      },
      "Shirt": {
        "required": [
          "brand",
          "color",
          "gender"
        ],
        "type": "object",
        "properties": {
          "shirtId": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "brand": {
            "type": [
              "null",
              "string"
            ]
          },
          "color": {
            "type": [
              "null",
              "string"
            ]
          },
          "size": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "null",
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "gender": {
            "type": [
              "null",
              "string"
            ]
          },
          "price": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?(?:[eE][+-]?\\d+)?$",
            "type": [
              "null",
              "number",
              "string"
            ],
            "format": "double"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Authority"
    },
    {
      "name": "Shirts"
    }
  ]
}